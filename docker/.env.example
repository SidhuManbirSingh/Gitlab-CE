# --- DATABASE CONFIGURATION ---

# The name for the PostgreSQL database
POSTGRES_DB=gitlabhq_production

# The database administrative user
POSTGRES_USER=gitlab

# A placeholder for the database password (CHANGE THIS in your real .env)
POSTGRES_PASSWORD=secure_db_password_placeholder

# --- GITLAB CONFIGURATION ---

# The password for the 'root' user on first login
GITLAB_ROOT_PASSWORD=initial_root_password_placeholder

# Your VM's IP or 'localhost'
GITLAB_HOSTNAME=localhost

# The full URL used to access GitLab (include the port you choose)
GITLAB_EXTERNAL_URL=http://localhost:8080

# --- RUNNER CONFIGURATION ---

# This will be generated once GitLab is running
GITLAB_RUNNER_TOKEN=registration_token_placeholder

## this is the reference what is the inside of the .env file, 
## I have changed the placeholder values with my own secure values before running the docker-compose up command.